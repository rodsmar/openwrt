From: Felix Fietkau <nbd@nbd.name>
Date: Wed, 10 Jul 2024 12:25:46 +0200
Subject: [PATCH] wifi: mac80211: add per-vif-link itxq

These tx queues are used for broadcast traffic, which could be sent out at
different rates on different links based on broadcast rate and channel
capacity.

Signed-off-by: Felix Fietkau <nbd@nbd.name>
---

--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -703,11 +703,14 @@ struct ieee80211_fils_discovery {
  *	beamformee
  * @eht_mu_beamformer: in AP-mode, does this BSS enable operation as an EHT MU
  *	beamformer
+ * @txq: the multicast data TX queue
  */
 struct ieee80211_bss_conf {
 	struct ieee80211_vif *vif;
 	struct cfg80211_bss *bss;
 
+	struct ieee80211_txq *txq;
+
 	const u8 *bssid;
 	unsigned int link_id;
 	u8 addr[ETH_ALEN] __aligned(2);
@@ -2536,6 +2539,7 @@ struct ieee80211_txq {
 	struct ieee80211_sta *sta;
 	u8 tid;
 	u8 ac;
+	u8 link_id;
 
 	/* must be last */
 	u8 drv_priv[] __aligned(sizeof(void *));
--- a/net/mac80211/iface.c
+++ b/net/mac80211/iface.c
@@ -2137,6 +2137,7 @@ int ieee80211_if_add(struct ieee80211_lo
 		if (txq_size) {
 			txqi = netdev_priv(ndev) + size;
 			ieee80211_txq_init(sdata, NULL, txqi, 0);
+			sdata->vif.bss_conf.txq = sdata->vif.txq = &txqi->txq;
 		}
 
 		sdata->dev = ndev;
--- a/net/mac80211/link.c
+++ b/net/mac80211/link.c
@@ -81,6 +81,7 @@ void ieee80211_link_stop(struct ieee8021
 struct link_container {
 	struct ieee80211_link_data data;
 	struct ieee80211_bss_conf conf;
+	struct txq_info txqi;
 };
 
 static void ieee80211_tear_down_links(struct ieee80211_sub_if_data *sdata,
@@ -206,7 +207,9 @@ static int ieee80211_vif_update_links(st
 
 	/* allocate new link structures first */
 	for_each_set_bit(link_id, &add, IEEE80211_MLD_MAX_NUM_LINKS) {
-		link = kzalloc(sizeof(*link), GFP_KERNEL);
+		size_t size = ALIGN(sizeof(*link), sizeof(void *));
+
+		link = kzalloc(size + sdata->local->hw.txq_data_size, GFP_KERNEL);
 		if (!link) {
 			ret = -ENOMEM;
 			goto free;
@@ -248,6 +251,9 @@ static int ieee80211_vif_update_links(st
 		link = links[link_id];
 		ieee80211_link_init(sdata, link_id, &link->data, &link->conf);
 		ieee80211_link_setup(&link->data);
+		ieee80211_txq_init(sdata, NULL, &link->txqi, 0);
+		link->txqi.txq.link_id = link_id;
+		link->conf.txq = &link->txqi.txq;
 	}
 
 	if (new_links == 0)
--- a/net/mac80211/tx.c
+++ b/net/mac80211/tx.c
@@ -1292,12 +1292,13 @@ ieee80211_tx_prepare(struct ieee80211_su
 }
 
 static struct txq_info *ieee80211_get_txq(struct ieee80211_local *local,
-					  struct ieee80211_vif *vif,
+					  struct ieee80211_sub_if_data *sdata,
 					  struct sta_info *sta,
 					  struct sk_buff *skb)
 {
 	struct ieee80211_hdr *hdr = (struct ieee80211_hdr *) skb->data;
 	struct ieee80211_tx_info *info = IEEE80211_SKB_CB(skb);
+	struct ieee80211_link_data *link;
 	struct ieee80211_txq *txq = NULL;
 
 	if ((info->flags & IEEE80211_TX_CTL_SEND_AFTER_DTIM) ||
@@ -1308,7 +1309,7 @@ static struct txq_info *ieee80211_get_tx
 	    unlikely(!ieee80211_is_data_present(hdr->frame_control))) {
 		if ((!ieee80211_is_mgmt(hdr->frame_control) ||
 		     ieee80211_is_bufferable_mmpdu(skb) ||
-		     vif->type == NL80211_IFTYPE_STATION) &&
+		     sdata->vif.type == NL80211_IFTYPE_STATION) &&
 		    sta && sta->uploaded) {
 			/*
 			 * This will be NULL if the driver didn't set the
@@ -1324,7 +1325,15 @@ static struct txq_info *ieee80211_get_tx
 
 		txq = sta->sta.txq[tid];
 	} else {
-		txq = vif->txq;
+		u8 link_id = u32_get_bits(info->control.flags,
+					  IEEE80211_TX_CTRL_MLO_LINK);
+
+		txq = sdata->vif.txq;
+		if (link_id != IEEE80211_LINK_UNSPECIFIED) {
+			link = rcu_dereference(sdata->link[link_id]);
+			if (link)
+				txq = link->conf->txq;
+		}
 	}
 
 	if (!txq)
@@ -1513,7 +1522,6 @@ void ieee80211_txq_init(struct ieee80211
 	txqi->txq.vif = &sdata->vif;
 
 	if (!sta) {
-		sdata->vif.txq = &txqi->txq;
 		txqi->txq.tid = 0;
 		txqi->txq.ac = IEEE80211_AC_BE;
 
@@ -1654,7 +1662,7 @@ static bool ieee80211_queue_skb(struct i
 				     struct ieee80211_sub_if_data, u.ap);
 
 	vif = &sdata->vif;
-	txqi = ieee80211_get_txq(local, vif, sta, skb);
+	txqi = ieee80211_get_txq(local, sdata, sta, skb);
 
 	if (!txqi)
 		return false;
